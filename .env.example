# Environment Variables for Railway/Vercel Deployment

# ==================== CORE SETTINGS ====================
SECRET_KEY=your-secret-key-here
DEBUG=False

# ==================== DATABASE ====================
# For Railway: auto-configured
# For Vercel: Use Neon (https://neon.tech)
DATABASE_URL=postgresql://user:password@host:port/dbname

# ==================== HOSTING ====================
# For Railway:
ALLOWED_HOSTS=your-domain.railway.app,localhost,127.0.0.1

# For Vercel:
# ALLOWED_HOSTS=your-project.vercel.app,localhost

# ==================== JUDGE0 API (VERCEL ONLY) ====================
# Get from: https://rapidapi.com/judge0-api/api/judge0-ce
# Required for Vercel deployment, optional for Railway
JUDGE0_API_KEY=

# ==================== JWT SETTINGS ====================
JWT_SECRET_KEY=your-jwt-secret-key

# ==================== EMAIL SETTINGS (optional) ====================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# ==================== CODE EXECUTION ====================
# For Railway with Docker:
USE_DOCKER=true
# For Vercel (serverless):
# USE_DOCKER=false

EXECUTION_TIMEOUT=10

# ==================== REDIS (optional) ====================
REDIS_URL=redis://localhost:6379

# ==================== CUSTOM DOMAIN (optional) ====================
CUSTOM_DOMAIN=
