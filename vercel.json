{
  "buildCommand": "pip install -r requirements.txt && python manage.py migrate && python manage.py collectstatic --noinput",
  "devCommand": "python manage.py runserver",
  "framework": "django",
  "env": {
    "PYTHON_VERSION": "3.11"
  },
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1",
      "headers": {
        "Cache-Control": "public, max-age=3600, s-maxage=3600"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/api/wsgi.py"
    }
  ],
  "functions": {
    "api/wsgi.py": {
      "memory": 3008,
      "maxDuration": 60
    }
  }
}
